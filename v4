<header>
  <h1 id="gTitle">團購標題</h1>
  <div class="host" id="gHost">團主</div>
  <div class="info-row">
    <div class="info-pill"><b>截止日期</b><span id="gDeadline"></span></div>
    <div class="info-pill"><b>取貨／出貨</b><span id="gPickup"></span></div>
  </div>
</header>

<nav class="tabs" id="tabs"></nav>

<main class="products" id="products">
  <div class="loading"><div class="spinner"></div>商品載入中…</div>
</main>

<!-- ========== 底部購物車 ========== -->
<div class="cartbar">
  <div class="handle" id="cartHandle">
    <div class="left">
      <div class="cart-ico">🛒<span class="dot" id="cartCount">0</span></div>
      <div class="total">合計<b id="cartTotal">$0</b></div>
    </div>
    <div class="toggle"><span id="toggleText">查看明細</span> <span id="toggleArrow">▲</span></div>
  </div>
  <div class="cart-panel" id="cartPanel">
    <div class="cart-inner">
      <div id="cartList"></div>
      <div class="checkout" id="checkout" style="display:none;">
        <h3>填寫取貨資料</h3>
        <div class="field" id="f-name">
          <label>訂購人姓名 <span class="req">*</span></label>
          <input type="text" id="inName" placeholder="請輸入姓名" autocomplete="name">
          <div class="err">請填寫姓名</div>
        </div>
        <div class="field" id="f-phone">
          <label>聯絡電話 <span class="req">*</span></label>
          <input type="tel" id="inPhone" placeholder="例：0912345678" inputmode="numeric" autocomplete="tel">
          <div class="err">請填寫正確的電話號碼</div>
        </div>
        <div class="field" id="f-email">
          <label>Email（選填，用於寄送電子發票）</label>
          <input type="email" id="inEmail" placeholder="example@gmail.com" autocomplete="email" inputmode="email">
          <div class="err">Email 格式不正確，請再確認</div>
        </div>
        <div class="field" id="f-pickup">
          <label>取貨方式 <span class="req">*</span></label>
          <select id="inPickup"><option value="">請選擇</option></select>
          <div class="err">請選擇取貨方式</div>
        </div>
        <div id="pickupExtra"></div>
        <div class="field" id="f-note">
          <label>備註（選填）</label>
          <textarea id="inNote" rows="2" placeholder="例：希望到貨時間、樓層、其他叮嚀…"></textarea>
        </div>
        <div class="checkout-total">
          <span>訂單總金額</span><b id="coTotal">$0</b>
        </div>
        <button class="submit-btn" id="submitBtn">送出訂單</button>
      </div>
    </div>
  </div>
</div>

<!-- ========== 頁內相簿 ========== -->
<div class="lightbox" id="lightbox">
  <div class="lb-top">
    <span class="lb-count" id="lbCount"></span>
    <button class="lb-close" id="lbClose">×</button>
  </div>
  <div class="lb-name" id="lbName"></div>
  <div class="lb-track" id="lbTrack"></div>
  <div class="lb-dots" id="lbDots"></div>
  <div class="lb-hint">左右滑動看更多照片</div>
</div>

<!-- ========== 送出後摘要 ========== -->
<div class="overlay" id="overlay">
  <div class="receipt" id="receipt"></div>
</div>

<div class="toast" id="toast"></div>

<script>
/* ============ 工具 ============ */
const $ = id => document.getElementById(id);
const money = n => "$" + Number(n).toLocaleString("en-US");
const discPrice = (p, d) => Math.round(Number(p) * Number(d) / 100); // 折後單價

let PRODUCTS = [];
let CART = {};          // key -> {item, qty}
let currentCat = "全部";

function keyOf(p){ return [p.商品名稱,p.款式,p.尺寸,p.顏色].join("|"); }

// 把「圖片網址」拆成多張：支援換行或逗號分隔，只留 http(s) 連結
function parseImages(val){
  if(!val) return [];
  return String(val).split(/[\n,]+/).map(s=>s.trim()).filter(s=>/^https?:\/\//i.test(s));
}

function toast(msg){
  const t = $("toast"); t.textContent = msg; t.classList.add("show");
  clearTimeout(t._t); t._t = setTimeout(()=>t.classList.remove("show"), 1600);
}

/* ============ 載入商品 ============ */
async function loadProducts(){
  if(CONFIG.APPS_SCRIPT_URL){
    try{
      const res = await fetch(CONFIG.APPS_SCRIPT_URL + "?action=products");
      const data = await res.json();
      PRODUCTS = (data.products || []).filter(p => String(p.是否上架).trim() === "是");
    }catch(e){
      $("products").innerHTML = '<div class="empty-cat">商品載入失敗，請稍後再試或聯絡團主。</div>';
      return;
    }
  }else{
    PRODUCTS = DEMO_PRODUCTS.filter(p => String(p.是否上架).trim() === "是");
  }
  buildTabs();
  renderProducts();
}

/* ============ 分類標籤 ============ */
function buildTabs(){
  const cats = ["全部", ...[...new Set(PRODUCTS.map(p=>p.分類))]];
  const wrap = $("tabs"); wrap.innerHTML = "";
  cats.forEach(c=>{
    const b = document.createElement("button");
    b.className = "tab" + (c===currentCat?" active":"");
    b.textContent = c;
    b.onclick = ()=>{ currentCat=c; buildTabs(); renderProducts(); };
    wrap.appendChild(b);
  });
}

/* ============ 商品卡 ============ */
function renderProducts(){
  const list = currentCat==="全部" ? PRODUCTS : PRODUCTS.filter(p=>p.分類===currentCat);
  const box = $("products");
  if(!list.length){ box.innerHTML = '<div class="empty-cat">此分類目前沒有商品。</div>'; return; }
  box.innerHTML = "";
  list.forEach(p=>{
    const k = keyOf(p);
    const dp = discPrice(p.原售價, p.折數);
    const inCart = CART[k];
    const photos = parseImages(p.圖片網址);
    const hasPhoto = photos.length > 0;
    const badge = photos.length > 1 ? `📷 ${photos.length} 張`
                : (photos.length === 1 ? "🔍 看大圖" : "");
    const card = document.createElement("div");
    card.className = "card";
    card.innerHTML = `
      <div class="thumb${hasPhoto?" has-link":""}">${hasPhoto
          ? `<img src="${photos[0]}" alt="${p.商品名稱}" onerror="this.parentNode.innerHTML='<div class=\\'ph\\'>圖片<br>準備中</div>'">`
          : `<div class="ph">圖片<br>準備中</div>`}${hasPhoto?`<span class="more-badge">${badge}</span>`:""}</div>
      <div class="body">
        <div class="name">${p.商品名稱}</div>
        <div class="spec">
          ${p.款式?`<span>${p.款式}</span>`:""}
          ${p.尺寸?`<span>${p.尺寸}</span>`:""}
          ${p.顏色?`<span>${p.顏色}</span>`:""}
        </div>
        <div class="price-row">
          <span class="old">${money(p.原售價)}</span>
          <span class="new">${money(dp)}</span>
          <span class="disc">${p.折數}折</span>
        </div>
        <div class="action"></div>
      </div>`;
    const action = card.querySelector(".action");
    action.appendChild(inCart ? qtyControl(k) : addBtn(k, p));
    if(hasPhoto){
      const thumbEl = card.querySelector(".thumb.has-link");
      const title = [p.商品名稱, p.款式, p.尺寸, p.顏色].filter(Boolean).join(" / ");
      if(thumbEl) thumbEl.onclick = ()=>openLightbox(photos, title);
    }
    box.appendChild(card);
  });
}

function addBtn(k, p){
  const b = document.createElement("button");
  b.className = "add"; b.textContent = "＋ 加入";
  b.onclick = ()=>{ addToCart(p); toast("已加入購物車"); };
  return b;
}
function qtyControl(k){
  const wrap = document.createElement("div");
  wrap.className = "qty-badge";
  wrap.innerHTML = `<button class="minus">−</button><span class="q">${CART[k].qty}</span><button class="plus">＋</button>`;
  wrap.querySelector(".minus").onclick = ()=>changeQty(k,-1);
  wrap.querySelector(".plus").onclick = ()=>changeQty(k,1);
  return wrap;
}

/* ============ 購物車邏輯 ============ */
function addToCart(p){
  const k = keyOf(p);
  if(CART[k]) CART[k].qty++; else CART[k] = {item:p, qty:1};
  refreshAll();
}
function changeQty(k, delta){
  if(!CART[k]) return;
  CART[k].qty += delta;
  if(CART[k].qty <= 0) delete CART[k];
  refreshAll();
}
function removeItem(k){ delete CART[k]; refreshAll(); }

function cartTotals(){
  let count=0, total=0;
  for(const k in CART){
    const {item, qty} = CART[k];
    count += qty;
    total += discPrice(item.原售價, item.折數) * qty;
  }
  return {count, total};
}

function refreshAll(){
  renderProducts();
  renderCart();
  const {count, total} = cartTotals();
  $("cartCount").textContent = count;
  $("cartTotal").textContent = money(total);
  $("coTotal").textContent = money(total);
}

function renderCart(){
  const list = $("cartList");
  const keys = Object.keys(CART);
  if(!keys.length){
    list.innerHTML = '<div class="cart-empty">購物車是空的，先去挑幾樣吧 🛍️</div>';
    $("checkout").style.display = "none";
    return;
  }
  $("checkout").style.display = "block";
  list.innerHTML = "";
  keys.forEach(k=>{
    const {item, qty} = CART[k];
    const dp = discPrice(item.原售價, item.折數);
    const row = document.createElement("div");
    row.className = "cart-item";
    row.innerHTML = `
      <div class="ci-body">
        <div class="ci-name">${item.商品名稱}</div>
        <div class="ci-spec">${[item.款式,item.尺寸,item.顏色].filter(Boolean).join(" / ")}</div>
        <div class="ci-price"><span class="o">${money(item.原售價)}</span><span class="n">${money(dp)}</span> <small>×${item.折數}折</small></div>
        <div class="ci-qty">
          <button class="m">−</button><span class="q">${qty}</span><button class="p">＋</button>
        </div>
      </div>
      <div class="ci-right">
        <button class="rm">移除</button>
        <div class="ci-sub">${money(dp*qty)}</div>
      </div>`;
    row.querySelector(".m").onclick = ()=>changeQty(k,-1);
    row.querySelector(".p").onclick = ()=>changeQty(k,1);
    row.querySelector(".rm").onclick = ()=>removeItem(k);
    list.appendChild(row);
  });
}

/* ============ 展開／收合 ============ */
$("cartHandle").onclick = ()=>{
  const panel = $("cartPanel");
  const open = panel.classList.toggle("open");
  $("toggleArrow").textContent = open ? "▼" : "▲";
  $("toggleText").textContent = open ? "收合" : "查看明細";
};

/* ============ 依取貨方式帶出的欄位 ============ */
// 每種取貨方式要客人補填的欄位。type:"text" 一般輸入；type:"select" 下拉。
const PICKUP_EXTRA = {
  宅配: [
    { id:"recvName",  key:"收件人姓名", label:"收件人姓名", type:"text", placeholder:"請輸入收件人姓名", err:"請填寫收件人姓名" },
    { id:"recvPhone", key:"收件人電話", label:"收件人電話", type:"text", placeholder:"例：0912345678", err:"請填寫收件人電話", inputmode:"numeric" },
    { id:"recvAddr",  key:"宅配地址",   label:"收件地址",   type:"text", placeholder:"請填寫完整地址（含縣市、郵遞區號）", err:"請填寫收件地址" }
  ],
  超商: [
    { id:"cvsBrand",  key:"超商品牌",   label:"超商品牌",   type:"select", options:["7-11", "全家"], err:"請選擇超商品牌" },
    { id:"cvsStore",  key:"門市名稱",   label:"門市名稱",   type:"text", placeholder:"例：八德興豐門市", err:"請填寫門市名稱" },
    { id:"cvsNo",     key:"門市店號",   label:"門市店號",   type:"text", placeholder:"例：123456", err:"請填寫門市店號", inputmode:"numeric" },
    { id:"recvName",  key:"收件人姓名", label:"收件人姓名", type:"text", placeholder:"請輸入取貨人姓名", err:"請填寫收件人姓名" },
    { id:"recvPhone", key:"收件人電話", label:"收件人電話", type:"text", placeholder:"例：0912345678", err:"請填寫收件人電話", inputmode:"numeric" }
  ]
};

// 判斷目前選的取貨方式屬於哪一組補填欄位
function pickupKind(val){
  if(/宅配/.test(val)) return "宅配";
  if(/超商/.test(val)) return "超商";
  return "";
}
function currentExtraFields(){
  return PICKUP_EXTRA[pickupKind($("inPickup").value)] || [];
}

// 依選擇動態產生補填欄位
function renderPickupExtra(){
  const box = $("pickupExtra");
  const fields = currentExtraFields();
  if(!fields.length){ box.innerHTML = ""; return; }
  box.innerHTML = fields.map(f=>{
    const inner = f.type === "select"
      ? `<select id="${f.id}"><option value="">請選擇</option>${
          f.options.map(o=>`<option value="${o}">${o}</option>`).join("")}</select>`
      : `<input type="text" id="${f.id}" placeholder="${f.placeholder||""}"${
          f.inputmode?` inputmode="${f.inputmode}"`:""}>`;
    return `<div class="field" id="f-${f.id}">
      <label>${f.label} <span class="req">*</span></label>
      ${inner}
      <div class="err">${f.err}</div>
    </div>`;
  }).join("");
}

// 把補填欄位組成物件，各自對映到訂單表的獨立欄位（key）
function buildPickupPayload(){
  const out = {};
  currentExtraFields().forEach(f=>{
    out[f.key] = ($(f.id) && $(f.id).value.trim()) || "";
  });
  return out;
}

/* ============ 驗證 ============ */
function validate(){
  let ok = true;
  const name = $("inName").value.trim();
  const phone = $("inPhone").value.trim();
  const email = $("inEmail").value.trim();
  const pickup = $("inPickup").value;
  setInvalid("f-name", !name); if(!name) ok=false;
  const phoneOk = /^[0-9\-\+\s()]{6,}$/.test(phone);
  setInvalid("f-phone", !phoneOk); if(!phoneOk) ok=false;
  const emailOk = !email || /^[^\s@]+@[^\s@]+\.[^\s@]+$/.test(email); // 選填，填了才驗證
  setInvalid("f-email", !emailOk); if(!emailOk) ok=false;
  setInvalid("f-pickup", !pickup); if(!pickup) ok=false;
  // 依取貨方式帶出的欄位逐一驗證（皆必填）
  currentExtraFields().forEach(f=>{
    const el = $(f.id);
    const bad = !el || !el.value.trim();
    setInvalid("f-" + f.id, bad); if(bad) ok=false;
  });
  return ok; // 備註為選填，不驗證
}
function setInvalid(id, bad){ const el = $(id); if(el) el.classList.toggle("invalid", bad); }

/* ============ 送出訂單 ============ */
$("submitBtn").onclick = async ()=>{
  if(!Object.keys(CART).length){ toast("購物車是空的喔"); return; }
  if(!validate()){
    if(!$("cartPanel").classList.contains("open")) $("cartHandle").click();
    return;
  }
  const btn = $("submitBtn");
  btn.disabled = true; btn.textContent = "送出中…";

  const items = Object.values(CART).map(({item, qty})=>{
    const dp = discPrice(item.原售價, item.折數);
    return {
      商品名稱:item.商品名稱, 款式:item.款式||"", 尺寸:item.尺寸||"", 顏色:item.顏色||"",
      數量:qty, 原售價:Number(item.原售價), 折數:Number(item.折數),
      折後單價:dp, 小計:dp*qty
    };
  });
  const payload = {
    訂購人:$("inName").value.trim(),
    電話:$("inPhone").value.trim(),
    電子郵件:$("inEmail").value.trim(),
    取貨方式:$("inPickup").value,
    ...buildPickupPayload(),
    備註:$("inNote").value.trim(),
    items
  };

  try{
    let result;
    if(CONFIG.APPS_SCRIPT_URL){
      const res = await fetch(CONFIG.APPS_SCRIPT_URL, {
        method:"POST",
        headers:{"Content-Type":"text/plain;charset=utf-8"}, // 避開 CORS 預檢
        body: JSON.stringify({action:"order", ...payload})
      });
      result = await res.json();
      if(!result.ok) throw new Error(result.message || "寫入失敗");
    }else{
      // 示範模式：本地產生訂單編號（正式版由後端產生）
      result = { ok:true, orderId: demoOrderId(), demo:true };
    }
    showReceipt(result.orderId, payload, result.demo);
    CART = {}; refreshAll();
  }catch(e){
    toast("送出失敗，請稍後再試");
    btn.disabled = false; btn.textContent = "送出訂單";
  }
};

function demoOrderId(){
  const d = new Date();
  const p = n => String(n).padStart(2,"0");
  return "CG" + d.getFullYear() + p(d.getMonth()+1) + p(d.getDate()) +
         "-" + p(d.getHours()) + p(d.getMinutes()) + p(d.getSeconds());
}

/* ============ 送出後摘要 ============ */
function showReceipt(orderId, payload, demo){
  const total = payload.items.reduce((s,i)=>s+i.小計, 0);
  const itemsHtml = payload.items.map(i=>`
    <div class="r-item">
      <div>
        <div>${i.商品名稱} ×${i.數量}</div>
        <div class="ri-spec">${[i.款式,i.尺寸,i.顏色].filter(Boolean).join(" / ")} ・ ${i.折數}折</div>
      </div>
      <div>${money(i.小計)}</div>
    </div>`).join("");

  // 取貨補填欄位（依客人選的方式，有填才顯示）
  const extraKeys = ["收件人姓名","收件人電話","宅配地址","超商品牌","門市名稱","門市店號"];
  const extraHtml = extraKeys.filter(k=>payload[k]).map(k=>
    `<div class="r-line"><span class="l">${k}</span><span>${payload[k]}</span></div>`).join("");

  const b = CONFIG.BANK || {};
  const payLine = (label, value) => `
    <div class="pay-line">
      <span class="pl-l">${label}</span>
      <span class="pl-v">${value}</span>
      <button class="copy" data-copy="${value}">複製</button>
    </div>`;

  $("receipt").innerHTML = `
    <div class="check">✓</div>
    <h2>訂單已送出！</h2>
    <div class="ono">訂單編號　<b>${orderId}</b></div>
    <div class="r-line"><span class="l">訂購人</span><span>${payload.訂購人}</span></div>
    <div class="r-line"><span class="l">電話</span><span>${payload.電話}</span></div>
    ${payload.電子郵件?`<div class="r-line"><span class="l">Email</span><span>${payload.電子郵件}</span></div>`:""}
    <div class="r-line"><span class="l">取貨方式</span><span>${payload.取貨方式}</span></div>
    ${extraHtml}
    ${payload.備註?`<div class="r-line"><span class="l">備註</span><span>${payload.備註}</span></div>`:""}
    <div class="r-sec-title">訂購明細</div>
    ${itemsHtml}
    <div class="r-total"><span>總金額</span><b>${money(total)}</b></div>

    <div class="pay-box">
      <div class="pb-title">💳 請匯款至以下帳戶</div>
      <div class="pb-amt">應付金額<b>${money(total)}</b></div>
      ${payLine("銀行", b.銀行 || "")}
      ${payLine("戶名", b.戶名 || "")}
      ${payLine("帳號", b.帳號 || "")}
      ${b.統編 ? payLine("統編", b.統編) : ""}
    </div>

    <div class="report-box" id="reportBox">
      <div class="rb-title">✅ 匯款完成後，回報帳號後五碼</div>
      <div class="rb-sub">填入你「轉出帳號」的後五碼，方便團主對帳。可稍後再回報，但建議現在填寫。</div>
      <div class="report-row">
        <input type="tel" id="inLast5" maxlength="5" inputmode="numeric" placeholder="＿＿＿＿＿">
        <button class="rb-btn" id="reportBtn">我已匯款</button>
      </div>
      <div class="report-err" id="reportErr">請輸入 5 位數字</div>
      <div class="report-done" id="reportDone">已收到你的回報，謝謝！團主會盡快對帳 🙏</div>
    </div>

    <div class="r-note">${demo
      ? "目前為示範模式，訂單與回報均未實際寫入試算表。設定好 Apps Script 網址後即會自動存檔。"
      : "請截圖保存此畫面。後續到貨／取貨將另行通知。"}</div>
    <button class="done-btn" id="doneBtn">完成，繼續逛</button>`;

  $("overlay").classList.add("show");

  // 一鍵複製
  $("receipt").querySelectorAll(".copy").forEach(btn=>{
    btn.onclick = ()=>{
      const text = btn.getAttribute("data-copy");
      copyText(text);
      const old = btn.textContent; btn.textContent = "已複製"; btn.style.background = "#E7F2ED";
      setTimeout(()=>{ btn.textContent = old; btn.style.background = "#fff"; }, 1200);
    };
  });

  // 回報帳號後五碼
  $("reportBtn").onclick = ()=>reportLast5(orderId, demo);

  $("doneBtn").onclick = ()=>{
    $("overlay").classList.remove("show");
    $("submitBtn").disabled = false; $("submitBtn").textContent = "送出訂單";
    $("inName").value=""; $("inPhone").value=""; $("inEmail").value=""; $("inPickup").value=""; $("inNote").value="";
    renderPickupExtra();   // 清掉取貨方式帶出的欄位
    if($("cartPanel").classList.contains("open")) $("cartHandle").click();
  };
}

/* ============ 頁內相簿 ============ */
function openLightbox(photos, title){
  const track = $("lbTrack"), dots = $("lbDots");
  $("lbName").textContent = title || "";
  track.innerHTML = photos.map(src=>`
    <div class="lb-slide">
      <img src="${src}" alt="" onerror="this.parentNode.innerHTML='<div class=\\'lb-broken\\'>此張圖片無法顯示</div>'">
    </div>`).join("");
  dots.innerHTML = photos.length > 1
    ? photos.map((_,i)=>`<span class="lb-dot${i===0?" active":""}"></span>`).join("")
    : "";
  $("lightbox").querySelector(".lb-hint").style.display = photos.length > 1 ? "block" : "none";
  updateLbCount(0, photos.length);
  $("lightbox").classList.add("show");
  document.body.style.overflow = "hidden";
  track.scrollLeft = 0;

  track.onscroll = ()=>{
    const idx = Math.round(track.scrollLeft / track.clientWidth);
    updateLbCount(idx, photos.length);
    [...dots.children].forEach((d,i)=>d.classList.toggle("active", i===idx));
  };
}
function updateLbCount(idx, total){
  $("lbCount").textContent = total > 1 ? `${idx+1} / ${total}` : "";
}
function closeLightbox(){
  $("lightbox").classList.remove("show");
  document.body.style.overflow = "";
  $("lbTrack").onscroll = null;
}
$("lbClose").onclick = closeLightbox;
$("lightbox").onclick = (e)=>{ if(e.target.id === "lightbox" || e.target.classList.contains("lb-slide")) closeLightbox(); };

/* ============ 複製到剪貼簿 ============ */
function copyText(text){
  if(navigator.clipboard && navigator.clipboard.writeText){
    navigator.clipboard.writeText(text).catch(()=>fallbackCopy(text));
  }else{ fallbackCopy(text); }
}
function fallbackCopy(text){
  const ta = document.createElement("textarea");
  ta.value = text; ta.style.position="fixed"; ta.style.opacity="0";
  document.body.appendChild(ta); ta.select();
  try{ document.execCommand("copy"); }catch(e){}
  document.body.removeChild(ta);
}

/* ============ 回報帳號後五碼 ============ */
async function reportLast5(orderId, demo){
  const val = $("inLast5").value.trim();
  if(!/^\d{5}$/.test(val)){ $("reportErr").style.display = "block"; return; }
  $("reportErr").style.display = "none";
  const btn = $("reportBtn"); btn.disabled = true; btn.textContent = "送出中…";
  try{
    if(CONFIG.APPS_SCRIPT_URL && !demo){
      const res = await fetch(CONFIG.APPS_SCRIPT_URL, {
        method:"POST",
        headers:{"Content-Type":"text/plain;charset=utf-8"},
        body: JSON.stringify({action:"report", 訂單編號:orderId, 帳號後五碼:val})
      });
      const r = await res.json();
      if(!r.ok) throw new Error(r.message || "回報失敗");
    }
    $("reportBox").querySelector(".report-row").style.display = "none";
    $("reportBox").querySelector(".rb-sub").style.display = "none";
    $("reportDone").style.display = "block";
  }catch(e){
    toast("回報失敗，請稍後再試");
    btn.disabled = false; btn.textContent = "我已匯款";
  }
}

/* ============ 初始化 ============ */
function initHeader(){
  $("gTitle").textContent = CONFIG.GROUP_TITLE;
  $("gHost").textContent = CONFIG.HOST_NAME;
  $("gDeadline").textContent = CONFIG.DEADLINE;
  $("gPickup").textContent = CONFIG.PICKUP_NOTE;
  const sel = $("inPickup");
  CONFIG.PICKUP_OPTIONS.forEach(o=>{
    const opt = document.createElement("option");
    opt.value = o; opt.textContent = o; sel.appendChild(opt);
  });
  sel.onchange = renderPickupExtra;   // 選了取貨方式就帶出對應欄位
}
initHeader();
loadProducts();
