<!DOCTYPE html>
<html lang="zh-Hant">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
<title>寢谷家居 團購下單</title>
<style>
  :root{
    --green:#2F5D50; --green-d:#234539; --accent:#E07A4E;
    --bg:#F6F3EE; --card:#FFFFFF; --line:#E7E1D7;
    --text:#2B2B2B; --muted:#8A8276; --price:#C8472B;
    --radius:16px; --shadow:0 2px 10px rgba(0,0,0,.06);
  }
  *{box-sizing:border-box;-webkit-tap-highlight-color:transparent;}
  html,body{margin:0;padding:0;}
  body{
    font-family:-apple-system,BlinkMacSystemFont,"PingFang TC","Noto Sans TC","Microsoft JhengHei",sans-serif;
    background:var(--bg); color:var(--text); font-size:16px; line-height:1.6;
    padding-bottom:96px;
  }
  img{display:block;max-width:100%;}
  button{font-family:inherit;cursor:pointer;border:none;}

  /* ---------- 頂部團購資訊 ---------- */
  header{
    background:linear-gradient(135deg,var(--green),var(--green-d));
    color:#fff; padding:22px 18px 20px; border-radius:0 0 22px 22px;
  }
  header h1{margin:0 0 4px; font-size:22px; letter-spacing:.5px;}
  header .host{font-size:14px; opacity:.9; margin-bottom:14px;}
  .info-row{display:flex; gap:10px; flex-wrap:wrap;}
  .info-pill{
    background:rgba(255,255,255,.15); border:1px solid rgba(255,255,255,.25);
    padding:8px 12px; border-radius:12px; font-size:13.5px; flex:1 1 auto; min-width:46%;
  }
  .info-pill b{display:block; font-size:12px; opacity:.8; font-weight:500; margin-bottom:2px;}

  /* ---------- 分類標籤 ---------- */
  .tabs{
    position:sticky; top:0; z-index:30; background:var(--bg);
    display:flex; gap:8px; overflow-x:auto; padding:12px 14px;
    -webkit-overflow-scrolling:touch; scrollbar-width:none;
  }
  .tabs::-webkit-scrollbar{display:none;}
  .tab{
    flex:0 0 auto; padding:8px 16px; border-radius:999px;
    background:#fff; border:1px solid var(--line); color:var(--muted);
    font-size:15px; white-space:nowrap; transition:.15s;
  }
  .tab.active{background:var(--green); color:#fff; border-color:var(--green);}

  /* ---------- 商品卡 ---------- */
  .products{padding:4px 14px 20px; display:grid; gap:14px;}
  .card{
    background:var(--card); border-radius:var(--radius); box-shadow:var(--shadow);
    overflow:hidden; display:flex; gap:12px; padding:12px;
  }
  .card .thumb{
    width:96px; height:96px; flex:0 0 96px; border-radius:12px; overflow:hidden;
    background:#EFEAE1; display:flex; align-items:center; justify-content:center;
    position:relative;
  }
  .card .thumb img{width:100%; height:100%; object-fit:cover;}
  .card .thumb .ph{color:var(--muted); font-size:12px; text-align:center;}
  .card .thumb.has-link{cursor:pointer;}
  .card .thumb.has-link:active{opacity:.85;}
  .card .thumb .more-badge{
    position:absolute; left:0; right:0; bottom:0;
    background:rgba(0,0,0,.55); color:#fff; font-size:11px; text-align:center;
    padding:3px 0; letter-spacing:.5px;
  }

  /* ---------- 頁內相簿（lightbox）---------- */
  .lightbox{
    position:fixed; inset:0; z-index:120; background:rgba(0,0,0,.93);
    display:none; flex-direction:column;
  }
  .lightbox.show{display:flex;}
  .lb-top{display:flex; align-items:center; justify-content:space-between; padding:14px 18px; color:#fff;}
  .lb-count{font-size:15px; font-weight:600; letter-spacing:.5px;}
  .lb-close{
    background:rgba(255,255,255,.16); color:#fff; width:38px; height:38px;
    border-radius:50%; font-size:24px; line-height:1; display:flex; align-items:center; justify-content:center;
  }
  .lb-name{color:#fff; text-align:center; font-size:14px; opacity:.85; padding:0 16px 6px;}
  .lb-track{
    flex:1; display:flex; overflow-x:auto; overflow-y:hidden;
    scroll-snap-type:x mandatory; -webkit-overflow-scrolling:touch;
  }
  .lb-track::-webkit-scrollbar{display:none;}
  .lb-slide{
    flex:0 0 100%; scroll-snap-align:center; display:flex;
    align-items:center; justify-content:center; padding:0 12px;
  }
  .lb-slide img{max-width:100%; max-height:74vh; object-fit:contain; border-radius:8px;}
  .lb-slide .lb-broken{color:#999; font-size:14px;}
  .lb-dots{display:flex; gap:8px; justify-content:center; align-items:center; padding:16px; flex-wrap:wrap;}
  .lb-dot{width:8px; height:8px; border-radius:50%; background:rgba(255,255,255,.35); transition:.2s;}
  .lb-dot.active{background:#fff; transform:scale(1.25);}
  .lb-hint{color:rgba(255,255,255,.55); font-size:12px; text-align:center; padding-bottom:10px;}
  .card .body{flex:1; min-width:0; display:flex; flex-direction:column;}
  .card .name{font-size:16px; font-weight:600; margin:0 0 2px;}
  .card .spec{font-size:13px; color:var(--muted); margin-bottom:auto;}
  .card .spec span{
    display:inline-block; background:#F1ECE3; border-radius:6px;
    padding:1px 7px; margin:2px 4px 0 0; font-size:12px; color:#6B6357;
  }
  .price-row{display:flex; align-items:baseline; gap:8px; margin-top:6px;}
  .price-row .old{color:var(--muted); text-decoration:line-through; font-size:13px;}
  .price-row .new{color:var(--price); font-size:20px; font-weight:700;}
  .price-row .disc{
    background:#FBE9E1; color:var(--accent); font-size:12px; font-weight:600;
    padding:1px 6px; border-radius:6px;
  }
  .card .add{
    margin-top:8px; align-self:flex-end; background:var(--green); color:#fff;
    padding:8px 18px; border-radius:999px; font-size:15px; font-weight:600;
  }
  .card .add:active{background:var(--green-d);}
  .qty-badge{
    align-self:flex-end; margin-top:8px; display:flex; align-items:center; gap:14px;
    background:#EEF3F1; border-radius:999px; padding:5px 6px;
  }
  .qty-badge button{
    width:30px; height:30px; border-radius:50%; background:var(--green); color:#fff;
    font-size:20px; line-height:1; display:flex; align-items:center; justify-content:center;
  }
  .qty-badge .q{min-width:22px; text-align:center; font-weight:600;}

  .empty-cat{text-align:center; color:var(--muted); padding:40px 0;}

  /* ---------- 底部購物車 ---------- */
  .cartbar{
    position:fixed; left:0; right:0; bottom:0; z-index:50;
    background:#fff; box-shadow:0 -2px 14px rgba(0,0,0,.12);
    border-radius:18px 18px 0 0;
  }
  .cartbar .handle{
    display:flex; align-items:center; justify-content:space-between;
    padding:14px 18px;
  }
  .cartbar .handle .left{display:flex; align-items:center; gap:10px;}
  .cart-ico{position:relative; font-size:24px;}
  .cart-ico .dot{
    position:absolute; top:-6px; right:-8px; background:var(--accent); color:#fff;
    font-size:11px; min-width:18px; height:18px; border-radius:9px; text-align:center;
    line-height:18px; padding:0 3px; font-weight:700;
  }
  .cartbar .total{font-size:14px; color:var(--muted);}
  .cartbar .total b{font-size:20px; color:var(--price); margin-left:4px;}
  .cartbar .toggle{font-size:13px; color:var(--green); display:flex; align-items:center; gap:4px;}

  .cart-panel{
    max-height:0; overflow:hidden; transition:max-height .28s ease;
    border-top:1px solid var(--line);
  }
  .cart-panel.open{max-height:70vh; overflow-y:auto;}
  .cart-inner{padding:6px 16px 14px;}
  .cart-item{
    display:flex; gap:10px; padding:12px 0; border-bottom:1px dashed var(--line);
  }
  .cart-item:last-child{border-bottom:none;}
  .cart-item .ci-body{flex:1; min-width:0;}
  .cart-item .ci-name{font-size:15px; font-weight:600;}
  .cart-item .ci-spec{font-size:12px; color:var(--muted); margin-bottom:4px;}
  .cart-item .ci-price{font-size:13px;}
  .cart-item .ci-price .o{text-decoration:line-through; color:var(--muted); margin-right:6px;}
  .cart-item .ci-price .n{color:var(--price); font-weight:600;}
  .cart-item .ci-right{display:flex; flex-direction:column; align-items:flex-end; gap:8px;}
  .cart-item .ci-sub{font-weight:700; color:var(--text);}
  .cart-item .rm{background:none; color:var(--muted); font-size:12px; text-decoration:underline;}
  .ci-qty{display:flex; align-items:center; gap:12px; background:#F1ECE3; border-radius:999px; padding:4px 6px;}
  .ci-qty button{width:26px; height:26px; border-radius:50%; background:var(--green); color:#fff; font-size:18px; line-height:1;}
  .ci-qty .q{min-width:18px; text-align:center; font-weight:600; font-size:14px;}
  .cart-empty{text-align:center; color:var(--muted); padding:30px 0;}

  /* ---------- 結帳區 ---------- */
  .checkout{padding:6px 0 4px;}
  .checkout h3{margin:8px 0 10px; font-size:16px;}
  .field{margin-bottom:12px;}
  .field label{display:block; font-size:14px; margin-bottom:5px; color:#5a5347;}
  .field label .req{color:var(--price);}
  .field input, .field select, .field textarea{
    width:100%; padding:12px 14px; border:1px solid var(--line); border-radius:12px;
    font-size:16px; background:#FCFAF6; color:var(--text);
  }
  .field input:focus, .field select:focus, .field textarea:focus{
    outline:none; border-color:var(--green);
  }
  .field .err{color:var(--price); font-size:12.5px; margin-top:4px; display:none;}
  .field.invalid input, .field.invalid select{border-color:var(--price); background:#FDF0EC;}
  .field.invalid .err{display:block;}
  .checkout-total{
    display:flex; justify-content:space-between; align-items:center;
    padding:12px 0; font-size:16px; border-top:1px solid var(--line); margin-top:4px;
  }
  .checkout-total b{font-size:24px; color:var(--price);}
  .submit-btn{
    width:100%; background:var(--accent); color:#fff; font-size:18px; font-weight:700;
    padding:16px; border-radius:14px; margin-top:8px;
  }
  .submit-btn:disabled{background:#C9C2B6; }
  .submit-btn:active:not(:disabled){filter:brightness(.95);}

  /* ---------- 送出後摘要（彈窗）---------- */
  .overlay{
    position:fixed; inset:0; z-index:100; background:rgba(0,0,0,.45);
    display:none; align-items:flex-end; justify-content:center;
  }
  .overlay.show{display:flex;}
  .receipt{
    background:#fff; width:100%; max-width:520px; border-radius:20px 20px 0 0;
    padding:24px 20px 28px; max-height:88vh; overflow-y:auto;
    animation:slideup .3s ease;
  }
  @keyframes slideup{from{transform:translateY(40px);opacity:.5}to{transform:none;opacity:1}}
  .receipt .check{
    width:60px; height:60px; border-radius:50%; background:#E7F2ED; color:var(--green);
    font-size:34px; display:flex; align-items:center; justify-content:center; margin:0 auto 12px;
  }
  .receipt h2{text-align:center; margin:0 0 4px; font-size:20px;}
  .receipt .ono{
    text-align:center; color:var(--muted); font-size:14px; margin-bottom:16px;
  }
  .receipt .ono b{color:var(--green); font-size:16px; letter-spacing:.5px;}
  .r-line{display:flex; justify-content:space-between; font-size:14px; padding:4px 0;}
  .r-line .l{color:var(--muted);}
  .r-sec-title{font-weight:700; margin:14px 0 6px; font-size:15px;}
  .r-item{display:flex; justify-content:space-between; font-size:14px; padding:6px 0; border-bottom:1px dashed var(--line);}
  .r-item .ri-spec{color:var(--muted); font-size:12px;}
  .r-total{display:flex; justify-content:space-between; font-size:17px; font-weight:700; padding-top:12px; margin-top:6px; border-top:2px solid var(--green);}
  .r-total b{color:var(--price);}
  .r-note{background:#F6F3EE; border-radius:12px; padding:12px 14px; font-size:13px; color:#6B6357; margin-top:14px;}
  /* 匯款資訊區 */
  .pay-box{background:#FBF7F0; border:1px solid #EBDEC8; border-radius:14px; padding:14px 16px; margin-top:16px;}
  .pay-box .pb-title{font-weight:700; font-size:15px; color:var(--green-d); margin-bottom:4px; display:flex; align-items:center; gap:6px;}
  .pay-box .pb-amt{font-size:13px; color:var(--muted); margin-bottom:10px;}
  .pay-box .pb-amt b{color:var(--price); font-size:18px; margin-left:4px;}
  .pay-line{display:flex; align-items:center; justify-content:space-between; gap:10px; padding:7px 0; border-bottom:1px dashed #E7DAC4;}
  .pay-line:last-child{border-bottom:none;}
  .pay-line .pl-l{color:var(--muted); font-size:13px; flex:0 0 auto;}
  .pay-line .pl-v{font-size:15px; font-weight:600; text-align:right; word-break:break-all; flex:1;}
  .pay-line .copy{background:#fff; border:1px solid var(--line); color:var(--green); font-size:12px; padding:5px 10px; border-radius:8px; flex:0 0 auto;}
  .pay-line .copy:active{background:#EEF3F1;}
  /* 回報後五碼 */
  .report-box{margin-top:16px; background:#F3F6F4; border-radius:14px; padding:14px 16px;}
  .report-box .rb-title{font-weight:700; font-size:15px; margin-bottom:4px;}
  .report-box .rb-sub{font-size:12.5px; color:var(--muted); margin-bottom:10px;}
  .report-row{display:flex; gap:8px;}
  .report-row input{flex:1; padding:12px 14px; border:1px solid var(--line); border-radius:12px; font-size:18px; letter-spacing:4px; text-align:center; background:#fff;}
  .report-row input:focus{outline:none; border-color:var(--green);}
  .report-row .rb-btn{background:var(--green); color:#fff; font-weight:600; font-size:15px; padding:0 16px; border-radius:12px; white-space:nowrap;}
  .report-row .rb-btn:disabled{background:#C9C2B6;}
  .report-err{color:var(--price); font-size:12.5px; margin-top:6px; display:none;}
  .report-done{display:none; margin-top:12px; background:#E7F2ED; color:var(--green-d); border-radius:12px; padding:12px 14px; font-size:14px; text-align:center; font-weight:600;}
  .receipt .done-btn{
    width:100%; background:var(--green); color:#fff; font-size:16px; font-weight:600;
    padding:14px; border-radius:12px; margin-top:18px;
  }

  /* ---------- 載入 / 提示 ---------- */
  .loading{text-align:center; padding:60px 20px; color:var(--muted);}
  .spinner{
    width:34px; height:34px; border:3px solid var(--line); border-top-color:var(--green);
    border-radius:50%; margin:0 auto 14px; animation:spin .8s linear infinite;
  }
  @keyframes spin{to{transform:rotate(360deg)}}
  .toast{
    position:fixed; left:50%; bottom:110px; transform:translateX(-50%);
    background:#333; color:#fff; padding:10px 18px; border-radius:999px; font-size:14px;
    z-index:200; opacity:0; transition:opacity .25s; pointer-events:none;
  }
  .toast.show{opacity:.95;}
  @media(min-width:560px){
    body{max-width:520px; margin:0 auto; background:#fff;}
    .cartbar{max-width:520px; margin:0 auto;}
  }
</style>
</head>
